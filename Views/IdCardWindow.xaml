<Window x:Class="ImageAdjust.Views.IdCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ImageAdjust.ViewModels"
        xmlns:conv="clr-namespace:ImageAdjust.Converters"
        Title="{Binding WindowTitle}"
        Height="800" Width="1200"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrow">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="AdjustSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="-100"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="TickFrequency" Value="5"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Image Previews Area -->
        <Grid Grid.Row="0" Background="#2D2D2D">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Front Card (Left) -->
            <Border Grid.Column="0" Margin="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#3D3D3D" Padding="8" CornerRadius="6,6,0,0">
                        <TextBlock Text="الوجه الأمامي / Face avant (Recto)"
                                   Foreground="White" FontWeight="Bold"
                                   HorizontalAlignment="Center" FontSize="14"/>
                    </Border>

                    <Border Grid.Row="1" Background="#1A1A1A" CornerRadius="0,0,6,6">
                        <Grid>
                            <Image Source="{Binding FrontPreview}"
                                   Stretch="Uniform" Margin="16"/>

                            <!-- Crop overlay -->
                            <Border BorderBrush="#00FF88" BorderThickness="2"
                                    Visibility="{Binding IsCroppingFront, Converter={StaticResource BoolToVis}}"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    Margin="16"/>
                        </Grid>
                    </Border>

                    <Button Content="✂️ قص / Rogner"
                            Command="{Binding ToggleCropFrontCommand}"
                            Style="{StaticResource SmallButton}"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,8,8,0" Opacity="0.9"/>
                </Grid>
            </Border>

            <!-- Separator -->
            <Border Grid.Column="1" Background="#555555" Width="4"/>

            <!-- Back Card (Right) -->
            <Border Grid.Column="2" Margin="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#3D3D3D" Padding="8" CornerRadius="6,6,0,0">
                        <TextBlock Text="الوجه الخلفي / Face arrière (Verso)"
                                   Foreground="White" FontWeight="Bold"
                                   HorizontalAlignment="Center" FontSize="14"/>
                    </Border>

                    <Border Grid.Row="1" Background="#1A1A1A" CornerRadius="0,0,6,6">
                        <Grid>
                            <Image Source="{Binding BackPreview}"
                                   Stretch="Uniform" Margin="16"/>

                            <!-- Crop overlay -->
                            <Border BorderBrush="#FF8800" BorderThickness="2"
                                    Visibility="{Binding IsCroppingBack, Converter={StaticResource BoolToVis}}"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    Margin="16"/>
                        </Grid>
                    </Border>

                    <Button Content="✂️ قص / Rogner"
                            Command="{Binding ToggleCropBackCommand}"
                            Style="{StaticResource SmallButton}"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,8,8,0" Opacity="0.9"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Adjustments Panel -->
        <Border Grid.Row="1" Background="#F5F5F5" Padding="16,12"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Shadows -->
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="الظلال / Ombres" FontSize="12" Foreground="#555555"/>
                    <Slider Value="{Binding Settings.Shadows}" Style="{StaticResource AdjustSlider}"/>
                    <TextBlock Text="{Binding Settings.Shadows, StringFormat='{}{0}'}"
                               FontSize="11" Foreground="#0078D4" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Highlights -->
                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="الإضاءة / Hautes lumières" FontSize="12" Foreground="#555555"/>
                    <Slider Value="{Binding Settings.Highlights}" Style="{StaticResource AdjustSlider}"/>
                    <TextBlock Text="{Binding Settings.Highlights, StringFormat='{}{0}'}"
                               FontSize="11" Foreground="#0078D4" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Saturation -->
                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Text="التشبع / Saturation" FontSize="12" Foreground="#555555"/>
                    <Slider Value="{Binding Settings.Saturation}" Style="{StaticResource AdjustSlider}"/>
                    <TextBlock Text="{Binding Settings.Saturation, StringFormat='{}{0}'}"
                               FontSize="11" Foreground="#0078D4" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Contrast -->
                <StackPanel Grid.Column="3" Margin="0,0,12,0">
                    <TextBlock Text="التباين / Contraste" FontSize="12" Foreground="#555555"/>
                    <Slider Value="{Binding Settings.Contrast}" Style="{StaticResource AdjustSlider}"/>
                    <TextBlock Text="{Binding Settings.Contrast, StringFormat='{}{0}'}"
                               FontSize="11" Foreground="#0078D4" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Quick buttons -->
                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                    <Button Command="{Binding ResetAdjustmentsCommand}"
                            Content="🔄 إعادة / Reset"
                            Style="{StaticResource SecondaryButton}"
                            Height="30" Margin="0,0,0,4"/>
                    <Button Command="{Binding ResetCropCommand}"
                            Content="✂️ إعادة القص / Reset Crop"
                            Style="{StaticResource SecondaryButton}"
                            Height="30"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Bottom Action Bar -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           Foreground="#888888" FontSize="12">
                    <Run Text="💡 سيتم طباعة وجهين: الصفحة الأولى = الوجه الأمامي، الصفحة الثانية = الوجه الخلفي / Impression recto-verso : Page 1 = Recto, Page 2 = Verso"/>
                </TextBlock>

                <Button Grid.Column="1" Command="{Binding PrintIdCardCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Content="🖨️ طباعة البطاقة / Imprimer la carte"
                        Height="40" Padding="24,8"
                        Margin="0,0,12,0"/>

                <Button Grid.Column="2" IsCancel="True"
                        Style="{StaticResource SecondaryButton}"
                        Content="✖ إلغاء / Annuler"
                        Height="40" Padding="16,8"/>
            </Grid>
        </Border>

        <!-- Processing overlay -->
        <Border Grid.RowSpan="3" Background="#80FFFFFF"
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="جاري المعالجة... / Traitement en cours..." FontSize="20"
                           Foreground="#0078D4" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
