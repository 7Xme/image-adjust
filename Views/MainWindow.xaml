<Window x:Class="ImageAdjust.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ImageAdjust.ViewModels"
        xmlns:models="clr-namespace:ImageAdjust.Models"
        xmlns:conv="clr-namespace:ImageAdjust.Converters"
        Title="Image Adjust - معالجة صور البطاقة الوطنية / Traitement des photos CIN"
        Height="750" Width="1100"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <Style x:Key="ThumbnailBorder" TargetType="Border">
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Opacity="0.3" BlurRadius="8" ShadowDepth="3"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SelectedThumbnailBorder" TargetType="Border" BasedOn="{StaticResource ThumbnailBorder}">
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Opacity="0.5" BlurRadius="12" ShadowDepth="4" Color="#0078D4"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="12" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding OpenFolderCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Content="📂  فتح مجلد / Ouvrir un dossier"
                        Padding="16,8" Margin="0,0,12,0"/>

                <Border Grid.Column="1" Background="White" CornerRadius="4"
                        BorderBrush="#CCCCCC" BorderThickness="1"
                        VerticalAlignment="Center" Height="36">
                    <TextBlock Text="{Binding FolderPath, TargetNullValue='لم يتم اختيار مجلد / Aucun dossier sélectionné'}"
                               VerticalAlignment="Center" Margin="8,0"
                               Foreground="#555555"
                               TextTrimming="CharacterEllipsis"/>
                </Border>

                <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="12,0,0,0"
                           Foreground="#0078D4" FontWeight="SemiBold">
                    <Run Text="🖼 "/>
                    <Run Text="{Binding Images.Count}"/>
                    <Run Text=" صورة / images"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Image Gallery -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Background="#F9F9F9" Padding="8">
            <ItemsControl ItemsSource="{Binding Images}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" IsItemsHost="True"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ImageItem}">
                        <Border Cursor="Hand" MouseLeftButtonDown="Thumbnail_MouseDown">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Margin" Value="8"/>
                                    <Setter Property="Padding" Value="4"/>
                                    <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Setter Property="CornerRadius" Value="6"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Opacity="0.3" BlurRadius="8" ShadowDepth="3"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BorderBrush" Value="#0078D4"/>
                                            <Setter Property="BorderThickness" Value="3"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Opacity="0.5" BlurRadius="12" ShadowDepth="4" Color="#0078D4"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid Width="180" Height="220">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Selection indicator -->
                                <Border Grid.Row="0" Background="#500078D4"
                                        CornerRadius="4" Margin="3"
                                        Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="✓" FontSize="36"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <Image Grid.Row="0" Source="{Binding Thumbnail}"
                                       Stretch="Uniform" Margin="4"
                                       ToolTip="{Binding FileName}"/>

                                <TextBlock Grid.Row="1" Text="{Binding FileName}"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="4,0,4,6"
                                           FontSize="11" Foreground="#444444"
                                           MaxHeight="32" LineHeight="14"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Border Grid.Row="1" Background="#80FFFFFF"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="جاري التحميل... / Chargement en cours..." FontSize="18"
                           Foreground="#0078D4" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Bottom Action Bar -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="12"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Command="{Binding OpenAdjustCommand}"
                            IsEnabled="{Binding HasSingleSelection}"
                            Style="{StaticResource ActionButton}"
                            Content="🎨 تعديل / Ajuster"
                            Margin="0,0,8,0"/>

                    <Button Command="{Binding PrintSingleCommand}"
                            IsEnabled="{Binding HasSingleSelection}"
                            Style="{StaticResource ActionButton}"
                            Content="🖨️ طباعة / Imprimer"
                            Margin="0,0,8,0"/>

                    <Button Command="{Binding OpenIdCardCommand}"
                            IsEnabled="{Binding HasDoubleSelection}"
                            Style="{StaticResource PrimaryButton}"
                            Content="🪪 طباعة كبطاقة تعريف / Imprimer comme CIN"
                            Padding="20,8"/>
                </StackPanel>

                <TextBlock Grid.Column="2" VerticalAlignment="Center"
                           Foreground="#666666" FontSize="13">
                    <Run Text="تم الاختيار / Sélectionné: "/>
                    <Run Text="{Binding SelectedCount}"/>
                    <Run Text=" من / de "/>
                    <Run Text="{Binding Images.Count}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
